{
  "manifest_version": 3,
  "name": "Memoriq",
  "version": "0.2.0",
  "description": "Save AI conversations to your encrypted Memoriq vault.",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/memoriq-16.png",
    "32": "icons/memoriq-32.png",
    "48": "icons/memoriq-48.png",
    "128": "icons/memoriq-128.png"
  },
  "host_permissions": [
    "http://memoriq.local/*",
    "https://memoriq.me/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://x.com/i/grok*",
    "https://x.com/grok*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Memoriq",
    "default_icon": {
      "16": "icons/memoriq-16.png",
      "32": "icons/memoriq-32.png",
      "48": "icons/memoriq-48.png",
      "128": "icons/memoriq-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://memoriq.local/extension/connect*", "https://memoriq.me/extension/connect*"],
      "js": ["connect.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://claude.ai/*", "https://gemini.google.com/*", "https://grok.com/*", "https://x.com/i/grok*", "https://x.com/grok*"],
      "js": ["crypto.js", "extract.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
